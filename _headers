# Cloudflare Pages applies these headers to all responses.
# See: https://developers.cloudflare.com/pages/configuration/headers/

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), interest-cohort=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

# Static assets — moderate cache. No content hashing in filenames yet,
# so we don't want a year-long cache that would strand visitors on old CSS.
/assets/*
  Cache-Control: public, max-age=3600, must-revalidate

/favicon.ico
  Cache-Control: public, max-age=86400

/apple-touch-icon.png
  Cache-Control: public, max-age=86400
